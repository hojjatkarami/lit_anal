# ── LLM (OpenRouter) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
# Model to use, e.g. openai/gpt-4o, anthropic/claude-3.5-sonnet
OPENROUTER_MODEL=openai/gpt-4o
# Max parallel OpenRouter requests during synthesis (capped at 10)
OPENROUTER_MAX_CONCURRENT_REQUESTS=10

# ── Zotero ────────────────────────────────────────────────────────────────────
ZOTERO_API_KEY=your_zotero_api_key
# Numeric user/group ID (visible at zotero.org/settings/keys)
ZOTERO_LIBRARY_ID=0000000
# "user" or "group"
ZOTERO_LIBRARY_TYPE=user

# ── Database (SQLite) ─────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./lit_anal.db

# ── PDF storage ───────────────────────────────────────────────────────────────
# Local directory where downloaded PDFs are cached
PDF_DOWNLOAD_DIR=./data/pdfs

# Base directory for extracted format files (subdirs: markdown/, html/, json/, doctags/)
EXTRACTION_DIR=./data/extractions
# Enable/disable writing each format on extraction
EXTRACTION_WRITE_MARKDOWN=true
EXTRACTION_WRITE_HTML=true
EXTRACTION_WRITE_JSON=true
EXTRACTION_WRITE_DOCTAGS=true

# ── Langfuse (optional – leave blank to disable tracing) ─────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# Self-hosted or cloud: https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
